# ==============================================
# DJANGO
# ==============================================
DEBUG=True
SECRET_KEY=django-insecure-change-me

# ==============================================
# OPENROUTER
# ==============================================
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# ==============================================
# MARKER INGEST (RAG)
# ==============================================
RAG_INGEST_MARKER_ENABLED=1
RAG_INGEST_MARKER_FALLBACK_ENABLED=1
RAG_INGEST_MARKER_TRAFFIC_PCT=100
RAG_INGEST_MARKER_ALLOWED_EXTS=pdf,docx,doc,pptx,ppt,xlsx,xls,html,htm,epub,png,jpg,jpeg,gif,bmp,webp,csv
RAG_INGEST_MARKER_USE_LLM=0
RAG_INGEST_MARKER_FORCE_OCR=0
RAG_INGEST_MARKER_DISABLE_IMAGE_EXTRACTION=1
RAG_INGEST_MARKER_OUTPUT_FORMAT=markdown
RAG_INGEST_MARKER_PAGINATE_OUTPUT=1
RAG_INGEST_MARKER_TIMEOUT_SEC=180

# ==============================================
# MODEL CACHE (set default ke folder project)
# ==============================================
RAG_MODEL_CACHE_BASE_DIR=./model_cache
HF_HOME=./model_cache/huggingface
TRANSFORMERS_CACHE=./model_cache/huggingface
TORCH_HOME=./model_cache/torch
MODEL_CACHE_DIR=./model_cache/datalab/Cache/models
